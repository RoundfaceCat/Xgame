    congratsText.setString("完美通关！\n特斯拉汽车兑换资格确认中...");
    congratsText.setCharacterSize(20);
    congratsText.setFillColor(sf::Color::Red);
    
    teslaFrame.setSize({w - 40.f, 200.f});
    teslaFrame.setFillColor(sf::Color(100, 100, 100)); 
}

void EasterEggWin::renderContent(sf::RenderWindow& win) {
    congratsText.setPosition(position.x + 20.f, position.y + 40.f);
    win.draw(congratsText);
    
    int r = (int)(127 + 128 * sin(animationClock.getElapsedTime().asSeconds() * 5.f));
    teslaFrame.setFillColor(sf::Color(r, 50, 50));
    teslaFrame.setPosition(position.x + 20.f, position.y + 120.f);
