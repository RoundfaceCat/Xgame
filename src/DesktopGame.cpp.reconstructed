Desktop::Desktop() {
    g_Desktop = this;
}

Desktop::~Desktop() {
    for (auto* ic : icons) delete ic;
    for (auto* w : openWindows) delete w;
}

void Desktop::init(sf::RenderWindow& win) {
    renderWin = &win;
    if (!systemFont.loadFromFile("assets/simhei.ttf")) {
        systemFont.loadFromFile("C:/Windows/Fonts/simhei.ttf");
    }

    startTex.loadFromFile("assets/start.jpg");
    startTex.setSmooth(true);
    startSpr.setTexture(startTex);
    
    taskbarBg.setFillColor(C::TaskbarBg);
    clockText.setFont(systemFont);
    clockText.setCharacterSize(14);
    clockText.setFillColor(sf::Color::White);

    icons.push_back(new MyComputerIcon({40.f, 40.f}, "assets/folder.jpg", systemFont));
    icons.push_back(new MyDocIcon({40.f, 160.f}, "assets/folder.jpg", systemFont));
    icons.push_back(new IEIcon({40.f, 280.f}, "assets/notepad.jpg", systemFont));
    icons.push_back(new NotepadIcon({40.f, 400.f}, "assets/notepad.jpg", systemFont));
    icons.push_back(new RecycleBinIcon({40.f, 520.f}, "assets/recycle.jpg", systemFont));

    for (auto* ic : icons) {
        ic->setupRightMenu();
    }
}

void Desktop::addWindow(GameWindow* win) {
    openWindows.push_back(win);
}

void Desktop::updateTaskbar() {
    taskbarBg.setSize({WIN_W, TASKBAR_H});
    taskbarBg.setPosition(0, WIN_H - TASKBAR_H);
    startSpr.setPosition(5.f, WIN_H - TASKBAR_H + 5.f);
    clockText.setString(getTimeString());
    clockText.setPosition(WIN_W - 80.f, WIN_H - 40.f);
}

void Desktop::processEvents() {
    sf::Event event;
    while (renderWin->pollEvent(event)) {
        if (event.type == sf::Event::Closed) renderWin->close();
        sf::Vector2f mPos = sf::Vector2f(sf::Mouse::getPosition(*renderWin));
        
        if (event.type == sf::Event::MouseMoved) {
            for (auto* w : openWindows) w->dragUpdate(mPos);
            // Hide context menus if hover changes can be placed here, but simpler logic suffices.
        }

        if (event.type == sf::Event::MouseButtonPressed) {
            bool handled = false;
            
            // Context Menu interactions
            for (auto* ic : icons) {
                if (ic->rightMenu.visible) {
                    if (event.mouseButton.button == sf::Mouse::Left && ic->rightMenu.isMouseHit(mPos)) {
                        int idx = ic->rightMenu.itemAt(sf::Mouse::getPosition(*renderWin));
                        if (idx != -1) ic->rightMenu.items[idx].action();
                        handled = true;
                    }
                    ic->rightMenu.hide(); // Hide all menus on click
                }
            }
            if (handled) continue;

            // Windows
            for (int i = (int)openWindows.size() - 1; i >= 0; --i) {
                GameWindow* w = openWindows[i];
                if (!w->isOpen || w->isMinimized) continue;
                if (w->isMouseHit(mPos)) {
                    if (i != openWindows.size() - 1) { // Bring to front
                        openWindows.erase(openWindows.begin() + i);
                        openWindows.push_back(w);
                    }
                    if (event.mouseButton.button == sf::Mouse::Left) {
                        if (w->containsCloseBtn(mPos)) w->closeWindow();
                        else if (w->containsTitleBar(mPos)) {
                            w->isDraging = true;
                            w->dragOffset = mPos - w->position;
                        } else w->handleInput(event);
                    } else w->handleInput(event);
                    handled = true;
                    break;
                }
            }
            if (handled) continue;

            // Icons
            for (auto* ic : icons) {
                if (ic->isMouseHit(mPos)) {
                    for (auto* other : icons) other->selected = false;
                    ic->selected = true;

                    if (event.mouseButton.button == sf::Mouse::Left) {
                        if (lastClickedIcon == ic && clickClock.getElapsedTime().asMilliseconds() < DOUBLE_CLICK_MS) {
                            ic->onClick();
                            lastClickedIcon = nullptr;
                        } else {
                            lastClickedIcon = ic;
                            clickClock.restart();
                        }
                    } else if (event.mouseButton.button == sf::Mouse::Right) {
                        ic->rightMenu.show(mPos, ic->rightMenu.items);
                    }
                    handled = true;
                    break;
                }
            }
            if (!handled && event.mouseButton.button == sf::Mouse::Left) {
                for (auto* ic : icons) ic->selected = false;
            }
        }

        if (event.type == sf::Event::MouseButtonReleased && event.mouseButton.button == sf::Mouse::Left) {
            for (auto* w : openWindows) w->isDraging = false;
        }

        if (event.type == sf::Event::TextEntered || event.type == sf::Event::KeyPressed) {
            if (!openWindows.empty()) {
                GameWindow* top = openWindows.back();
                if (top->isOpen && !top->isMinimized) top->handleInput(event);
            }
        }
    }

    // Dynamic Reward Unlock
    static bool rewardAdded = false;
    if (GameManager::getInstance().isRewardUnlocked && !rewardAdded) {
        RewardExeIcon* reward = new RewardExeIcon({40.f, 640.f}, "assets/notepad.jpg", systemFont);
        reward->setupRightMenu();
        icons.push_back(reward);
        rewardAdded = true;
    }

    // Garbage collection
    openWindows.erase(std::remove_if(openWindows.begin(), openWindows.end(), [](GameWindow* w) {
        if (!w->isOpen) { delete w; return true; }
        return false;
    }), openWindows.end());
}

void Desktop::renderAll() {
    renderWin->clear(C::DesktopBg);
    
    for (auto* ic : icons) ic->render(*renderWin);
    for (auto* w : openWindows) w->render(*renderWin);
    
    // Taskbar
    renderWin->draw(taskbarBg);
    renderWin->draw(startSpr);
    renderWin->draw(clockText);
    
    renderWin->display();
}

void Desktop::run() {
    while (renderWin->isOpen()) {
        processEvents();
        updateTaskbar();
        renderAll();
    }
}
