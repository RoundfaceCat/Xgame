MsgBoxWin::MsgBoxWin(const std::string& boxTitle, const std::string& message, sf::Vector2f p, float w, float h, const sf::Font& font)
    : GameWindow(boxTitle, p, w, h, font) {
    msgText.setFont(font);
    msgText.setString(message);
    msgText.setCharacterSize(14);
    msgText.setFillColor(sf::Color::Black);

    okBtn.setSize({80.f, 30.f});
    okBtn.setFillColor(C::WindowBody);
    
    okBtnText.setFont(font);
    okBtnText.setString("确定");
    okBtnText.setCharacterSize(14);
    okBtnText.setFillColor(sf::Color::Black);
}

void MsgBoxWin::renderContent(sf::RenderWindow& win) {
    msgText.setPosition(position.x + 20.f, position.y + 40.f);
    win.draw(msgText);

    okBtn.setPosition(position.x + width / 2.f - 40.f, position.y + height - 40.f);
    win.draw(okBtn);
    drawDoubleBevel(win, {okBtn.getPosition().x, okBtn.getPosition().y, 80.f, 30.f}, true);

    okBtnText.setPosition(okBtn.getPosition().x + 24.f, okBtn.getPosition().y + 6.f);
    win.draw(okBtnText);
}

void MsgBoxWin::handleInput(sf::Event& event) {
    if (event.type == sf::Event::MouseButtonPressed && event.mouseButton.button == sf::Mouse::Left) {
        sf::FloatRect btnBounds(okBtn.getPosition().x, okBtn.getPosition().y, 80.f, 30.f);
        if (btnBounds.contains((float)event.mouseButton.x, (float)event.mouseButton.y)) {
            closeWindow();
        }
    }
}

// EasterEggWin
EasterEggWin::EasterEggWin(sf::Vector2f p, float w, float h, const sf::Font& font)
    : GameWindow("TESLA PRIZE", p, w, h, font) {
