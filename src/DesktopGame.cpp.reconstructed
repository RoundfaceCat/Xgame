    win.draw(promptText);

    inputField.setSize({width - 40.f, 30.f});
    inputField.setPosition(position.x + 20.f, position.y + 90.f);
    win.draw(inputField);

    inputText.setString(typedPassword + "_");
    inputText.setPosition(position.x + 25.f, position.y + 95.f);
    win.draw(inputText);
}

void PasswordInputWin::handleInput(sf::Event& event) {
    if (event.type == sf::Event::TextEntered) {
        if (event.text.unicode == '\b') {
            if (!typedPassword.empty()) typedPassword.pop_back();
        } else if (event.text.unicode == '\r') {
            auto& gm = GameManager::getInstance();
            if (typedPassword == gm.fullKey) {
                closeWindow();
                if (g_Desktop) {
                    for (auto* w : g_Desktop->openWindows) {
                        if (auto bw = dynamic_cast<BrowserWin*>(w)) bw->showSecretPage = true;
                    }
                    g_Desktop->addWindow(new EasterEggWin({position.x - 100, position.y - 100}, 500.f, 400.f, winFont));
                }
            }
            else if (typedPassword == gm.keyPart1) {
                closeWindow();
                gm.recycleBinUnlocked = true;
                if (g_Desktop) g_Desktop->addWindow(new FileListWin("加密档案室", false, {position.x, position.y}, 600.f, 400.f, winFont));
            } else {
                hasError = true;
                typedPassword.clear();
            }
        } else if (event.text.unicode < 128) {
            typedPassword += static_cast<char>(event.text.unicode);
            hasError = false;
        }
    }
}

