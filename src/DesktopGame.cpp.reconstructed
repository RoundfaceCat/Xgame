// ── Helpers ────────────────────────────────────────────────────
void drawDoubleBevel(sf::RenderWindow& win, sf::FloatRect rect, bool raised) {
    sf::RectangleShape line;
    // Outer
    line.setFillColor(raised ? C::BevelLight : C::BevelDark);
    line.setSize({rect.width, 2.f});
    line.setPosition(rect.left, rect.top);
    win.draw(line);
    line.setSize({2.f, rect.height});
    win.draw(line);

    line.setFillColor(raised ? C::BevelDark : C::BevelLight);
    line.setSize({rect.width, 2.f});
    line.setPosition(rect.left, rect.top + rect.height - 2.f);
    win.draw(line);
    line.setSize({2.f, rect.height});
    line.setPosition(rect.left + rect.width - 2.f, rect.top);
    win.draw(line);

    // Inner
    sf::FloatRect in(rect.left + 2.f, rect.top + 2.f, rect.width - 4.f, rect.height - 4.f);
    line.setFillColor(raised ? C::BevelMedium : C::BevelMedium);
    line.setSize({in.width, 2.f});
    line.setPosition(in.left, in.top);
    win.draw(line);
    line.setSize({2.f, in.height});
    win.draw(line);

    line.setFillColor(raised ? C::BevelMedium : C::BevelLight); 
    line.setSize({in.width, 2.f});
    line.setPosition(in.left, in.top + in.height - 2.f);
    win.draw(line);
    line.setSize({2.f, in.height});
    line.setPosition(in.left + in.width - 2.f, in.top);
    win.draw(line);
}

std::string getTimeString() {
    time_t now = time(nullptr);
    tm* ltm = localtime(&now);
    std::stringstream ss;
    ss << std::setfill('0') << std::setw(2) << ltm->tm_hour << ":" 
       << std::setfill('0') << std::setw(2) << ltm->tm_min;
    return ss.str();
}

// ── 2. ContextMenu ─────────────────────────────────────────────
ContextMenu::ContextMenu() : UIComponent({0.f, 0.f}, 300.f, 0.f), visible(false) {
    background.setFillColor(C::MenuBg);
}

void ContextMenu::setFont(const sf::Font& font) { menuFont = font; }

void ContextMenu::show(sf::Vector2f p, const std::vector<MenuItem>& newItems) {
    items = newItems;
    position = p;
    height = items.size() * itemHeight + 4.f;
    background.setSize({width, height});
    
    itemTexts.clear();
    for (const auto& item : items) {
        sf::Text t(item.label, menuFont, 14);
        itemTexts.push_back(t);
    }
    visible = true;
    hoveredIdx = -1;
}

void ContextMenu::hide() { visible = false; }

bool ContextMenu::isMouseHit(sf::Vector2f mp) {
    if (!visible) return false;
    return mp.x >= position.x && mp.x <= position.x + width &&
           mp.y >= position.y && mp.y <= position.y + height;
}

int ContextMenu::itemAt(sf::Vector2i mp) const {
    if (mp.x < position.x || mp.x > position.x + width || mp.y < position.y || mp.y > position.y + height) return -1;
    int idx = (mp.y - position.y - 2.f) / itemHeight;
    if (idx >= 0 && idx < items.size()) return idx;
    return -1;
}

void ContextMenu::updateHover(sf::Vector2i mp) { hoveredIdx = itemAt(mp); }

void ContextMenu::render(sf::RenderWindow& win) {
    if (!visible) return;
    background.setPosition(position);
    win.draw(background);
    drawDoubleBevel(win, {position.x, position.y, width, height}, true);

    for (size_t i = 0; i < items.size(); ++i) {
        float y = position.y + 2.f + i * itemHeight;
        if (i == hoveredIdx && items[i].enabled) {
            sf::RectangleShape hovRect({width - 4.f, itemHeight});
            hovRect.setPosition(position.x + 2.f, y);
            hovRect.setFillColor(C::MenuHover);
            win.draw(hovRect);
            itemTexts[i].setFillColor(sf::Color::White);
        } else {
            itemTexts[i].setFillColor(items[i].enabled ? C::TextWhite : sf::Color(150, 150, 150));
        }
        itemTexts[i].setPosition(position.x + 10.f, y + 4.f);
        win.draw(itemTexts[i]);
    }
}

// ── 3. DesktopIcon ─────────────────────────────────────────────
DesktopIcon::DesktopIcon(sf::Vector2f p, const std::string& lbl, const std::string& texPath, const sf::Font& font)
    : UIComponent(p, ICON_W, ICON_H), label(lbl) {
    if (iconTex.loadFromFile(texPath)) {
        iconTex.setSmooth(true);
        iconSpr.setTexture(iconTex);
    }
    labelText.setFont(font);
    labelText.setString(label);
    labelText.setCharacterSize(14);
    labelText.setFillColor(sf::Color::White);
    rightMenu.setFont(font);
}

void DesktopIcon::setupRightMenu() {
    rightMenu.items.clear();
    rightMenu.items.push_back({"Open", [this]() { this->onClick(); }, true});
}

void DesktopIcon::render(sf::RenderWindow& win) {
    if (!visible) return;
    iconSpr.setPosition(position);
    
    sf::FloatRect textBounds = labelText.getLocalBounds();
    labelText.setPosition(position.x + (width - textBounds.width) / 2.f, position.y + height + 5.f);

    if (selected) {
        iconSpr.setColor(sf::Color(128, 128, 255, 200));
        sf::RectangleShape textBg({textBounds.width + 10.f, textBounds.height + 6.f});
        textBg.setPosition(labelText.getPosition().x - 5.f, labelText.getPosition().y - 2.f);
        textBg.setFillColor(sf::Color(10, 36, 106));
        win.draw(textBg);
    } else {
        iconSpr.setColor(sf::Color::White);
    }

    win.draw(iconSpr);
    win.draw(labelText);
    if (rightMenu.visible) rightMenu.render(win);
}

bool DesktopIcon::isMouseHit(sf::Vector2f mp) {
    if (!visible) return false;
    return mp.x >= position.x && mp.x <= position.x + width &&
           mp.y >= position.y && mp.y <= position.y + height + 30.f; // Including label
}

// ── 4. GameWindow ──────────────────────────────────────────────
GameWindow::GameWindow(const std::string& t, sf::Vector2f p, float w, float h, const sf::Font& font)
    : UIComponent(p, w, h), title(t) {
    
    titleBar.setFillColor(C::WindowTitle);
    closeBtn.setFillColor(C::CloseBtn);
    frame.setFillColor(C::WindowBody);

    titleText.setFont(font);
    titleText.setString(title);
    titleText.setCharacterSize(14);
    titleText.setFillColor(C::WinTitleText);
}

void GameWindow::dragUpdate(sf::Vector2f mp) {
    if (isDraging) {
        position = mp - dragOffset;
        position.x = std::max(0.f, std::min(position.x, WIN_W - width));
        position.y = std::max(0.f, std::min(position.y, DESKTOP_H - height));
    }
}

void GameWindow::closeWindow() {
    isOpen = false;
}

bool GameWindow::containsTitleBar(sf::Vector2f mp) const {
    return mp.x >= position.x + 4.f && mp.x <= position.x + width - 8.f &&
           mp.y >= position.y + 4.f && mp.y <= position.y + 28.f;
}

bool GameWindow::containsCloseBtn(sf::Vector2f mp) const {
    return mp.x >= position.x + width - 28.f && mp.x <= position.x + width - 8.f &&
           mp.y >= position.y + 6.f && mp.y <= position.y + 26.f;
}

bool GameWindow::isMouseHit(sf::Vector2f mp) {
    if (!visible || !isOpen || isMinimized) return false;
    return mp.x >= position.x && mp.x <= position.x + width &&
           mp.y >= position.y && mp.y <= position.y + height;
}

void GameWindow::renderFrame(sf::RenderWindow& win) {
    // Background and Bevel
    frame.setSize({width, height});
    frame.setPosition(position);
    win.draw(frame);
    drawDoubleBevel(win, {position.x, position.y, width, height}, true);

    // Titlebar
    titleBar.setSize({width - 8.f, 24.f});
    titleBar.setPosition(position.x + 4.f, position.y + 4.f);
    win.draw(titleBar);
    titleText.setPosition(position.x + 9.f, position.y + 9.f);
    win.draw(titleText);

    // Close button
    closeBtn.setSize({20.f, 20.f});
    closeBtn.setPosition(position.x + width - 28.f, position.y + 6.f);
    win.draw(closeBtn);
    drawDoubleBevel(win, {position.x + width - 28.f, position.y + 6.f, 20.f, 20.f}, true);
}

void GameWindow::render(sf::RenderWindow& win) {
    if (!visible || !isOpen || isMinimized) return;
    renderFrame(win);
    renderContent(win);
}

