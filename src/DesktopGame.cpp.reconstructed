// FileListWin
FileListWin::FileListWin(const std::string& title, bool recycleBin, sf::Vector2f p, float w, float h, const sf::Font& font)
    : GameWindow(title, p, w, h, font), isRecycleBinMode(recycleBin), winFont(font) {
    refreshFiles();
}

void FileListWin::refreshFiles() {
    files.clear();
    auto& gm = GameManager::getInstance();
    
    if (title == "回收站") {
        isRecycleBinMode = true;
        if (!gm.recycleBinUnlocked) return;
        files.push_back({"特斯拉编号记录.txt", "txt", "后半段密钥为：2012"});
    } 
    else if (title == "加密档案室") {
        isRecycleBinMode = false;
        files.push_back({"密钥上半段.txt", "txt", "完整密钥 = 试飞日期 + 特斯拉Model S出厂编号\n\n后半段密钥已被永久删除至回收站。"});
    }
    else { // 我的文档
        isRecycleBinMode = false;
        files.push_back({"项目备忘录.txt", "txt", "日期：2003年10月22日\n\n主线线索：第一层密码为星舰首次轨道试飞日期。\n完整密钥分为两段，后半段已被我删除。"});
        files.push_back({"加密提示.doc", "doc", "加密文件夹入口藏于系统属性面板，\n不要只看桌面图标。"});
    }
}

void FileListWin::renderContent(sf::RenderWindow& win) {
    sf::RectangleShape contentBg({width - 12.f, height - 40.f});
    contentBg.setPosition(position.x + 6.f, position.y + 34.f);
    contentBg.setFillColor(sf::Color::White);
    win.draw(contentBg);
    drawDoubleBevel(win, {position.x + 6.f, position.y + 34.f, width - 12.f, height - 40.f}, false);

    float yOffset = position.y + 40.f;
    int idx = 0;
    for (auto& f : files) {
        sf::Text fText;
        fText.setFont(winFont);
        fText.setString((isRecycleBinMode ? "[已删除] " : "") + f.name);
        fText.setCharacterSize(16);
        fText.setPosition(position.x + 20.f, yOffset);

        if (idx == selectedIdx) {
            sf::RectangleShape selBg({width - 24.f, 20.f});
            selBg.setPosition(position.x + 12.f, yOffset);
            selBg.setFillColor(C::SelectBorder);
            win.draw(selBg);
            fText.setFillColor(sf::Color::White);
        } else {
            fText.setFillColor(sf::Color::Black);
        }
        win.draw(fText);
        yOffset += 24.f;
        idx++;
    }
}

void FileListWin::handleInput(sf::Event& event) {
    if (event.type == sf::Event::MouseButtonPressed && event.mouseButton.button == sf::Mouse::Left) {
        sf::Vector2i mp(event.mouseButton.x, event.mouseButton.y);
        int idx = (mp.y - (position.y + 40.f)) / 24.f;
        if (idx >= 0 && idx < files.size() && mp.x > position.x && mp.x < position.x + width) {
            
            // Double click logic for files
            if (selectedIdx == idx && g_Desktop && g_Desktop->clickClock.getElapsedTime().asMilliseconds() < DOUBLE_CLICK_MS) {
                g_Desktop->addWindow(new TextReadWin(files[idx].name, files[idx].content, {position.x + 50.f, position.y + 50.f}, 450.f, 350.f, winFont));
                g_Desktop->clickClock.restart();
            } else {
                selectedIdx = idx;
                if (g_Desktop) g_Desktop->clickClock.restart();
            }
        } else {
            selectedIdx = -1;
        }
    } else if (event.type == sf::Event::MouseButtonPressed && event.mouseButton.button == sf::Mouse::Right) {
        if (selectedIdx != -1 && isRecycleBinMode) {
            // Restore file to desktop
            std::string restoredName = files[selectedIdx].name;
            std::string restoredContent = files[selectedIdx].content;
            files.erase(files.begin() + selectedIdx);
            selectedIdx = -1;
            
            GameManager::getInstance().isRewardUnlocked = true;
            
            if (g_Desktop) {
                // Add the restored file to the desktop
                NotepadIcon* restoredIcon = new NotepadIcon({40.f, 640.f}, "assets/notepad.jpg", winFont);
                restoredIcon->label = restoredName;
                restoredIcon->setupRightMenu();
                // We override the default onClick to show the specific restored content
                restoredIcon->rightMenu.items[0].action = [restoredName, restoredContent, this]() {
                    g_Desktop->addWindow(new TextReadWin(restoredName, restoredContent, {150.f, 150.f}, 450.f, 300.f, winFont));
                };
                g_Desktop->icons.push_back(restoredIcon);
                
                g_Desktop->addWindow(new MsgBoxWin("还原成功", "《" + restoredName + "》已成功还原至桌面！\n(星舰奖励.exe 也已自动解锁)", {position.x+50, position.y+50}, 380.f, 180.f, winFont));
            }
        }
    }
}

